SITE_URL=http://localhost:5000

# ============================================
# FLASK CONFIGURATION
# ============================================
SECRET_KEY=your-secret-key-here
FLASK_ENV=production
FLASK_DEBUG=False

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_USERNAME=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eswatini_classifieds
DATABASE_URL=postgresql://username:password@host:port/dbname

# ============================================
# EMAIL CONFIGURATION
# ============================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=Eswatini Classifieds <your-email@gmail.com>
ADMIN_EMAIL=admin@example.com

# ============================================
# MTN MOMO API CONFIGURATION
# ============================================
MTN_MOMO_API_KEY=your-api-key
MTN_MOMO_API_USER=your-api-user
MTN_MOMO_API_SECRET=your-api-secret
MTN_MOMO_SUBSCRIPTION_KEY=your-subscription-key
MTN_MOMO_ENVIRONMENT=sandbox
MTN_MOMO_CURRENCY=SZL
MTN_MOMO_CALLBACK_URL=https://yourdomain.com/api/momo/callback

# ============================================
# SITE CONFIGURATION
# ============================================
SITE_URL=https://yourdomain.com
SITE_NAME=Eswatini Classifieds
SITE_DOMAIN=yourdomain.com

# ============================================
# SECURITY CONFIGURATION
# ============================================
RATE_LIMIT_REQUESTS=200
MAX_CONTENT_LENGTH=5242880

# ============================================
# ADMIN CONFIGURATION
# ============================================
ADMIN_EMAILS=admin@example.com

# ============================================
# PAYMENT CONFIGURATION
# ============================================
BANK_NAME=FNB Eswatini
BANK_ACCOUNT_NAME=Eswatini Classifieds
BANK_ACCOUNT_NUMBER=62345678901
BANK_BRANCH_CODE=280164